{
  "name": "integrity-backend",
  "version": "1.0.0",
  "description": "INTEGRITY API - Node.js + Express backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "db:seed": "node db/seed.js",
    "db:reset": "node db/reset.js",
    "seed:dummy": "node scripts/seed-dummy-data.js",
    "db:wipe": "node scripts/reset-database.js",
    "users:delete": "node scripts/delete-test-users.js",
    "users:create": "node scripts/create-test-users.js",
    "full:reset": "node scripts/full-reset-cli.js",
    "seed:graph": "node scripts/seed-graph-project-data.js"
  },
  "keywords": [
    "test-selection",
    "risk-assessment",
    "quality-analytics"
  ],
  "author": "INTEGRITY Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
