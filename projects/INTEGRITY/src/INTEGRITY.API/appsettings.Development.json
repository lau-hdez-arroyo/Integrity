{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Debug",
      "Microsoft.EntityFrameworkCore": "Debug"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=INTEGRITY_Dev;Trusted_Connection=true;MultipleActiveResultSets=true;",
    "Redis": "localhost:6379"
  },

  "Auth": {
    "Authority": "https://login.microsoftonline.com/[tenant-id]/v2.0",
    "Audience": "https://localhost:7001",
    "ClientId": "local-development",
    "ClientSecret": "local-secret-only"
  },

  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:3001,http://localhost:5173"
  },

  "Features": {
    "EnableHeatMapGeneration": true,
    "EnableTestSelection": true,
    "EnableRiskAssessment": true,
    "EnableRealTimeDashboards": true,
    "EnableMachineLearning": false,
    "EnableWebhooks": true
  },

  "Security": {
    "RequireHttps": false,
    "AllowInvalidCerts": true
  }
}
