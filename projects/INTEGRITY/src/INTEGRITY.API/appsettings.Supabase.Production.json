{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=[SUPABASE_HOST];Port=5432;Database=postgres;Username=postgres;Password=[SUPABASE_PASSWORD];SSL Mode=Require;Include Error Detail=false;",
    "Supabase": "postgresql://postgres:[SUPABASE_PASSWORD]@[SUPABASE_HOST]:5432/postgres?sslmode=require"
  },

  "Supabase": {
    "Url": "https://[PROJECT_ID].supabase.co",
    "Key": "[SERVICE_ROLE_KEY]",
    "AnonKey": "[ANON_KEY]"
  },

  "Auth": {
    "Authority": "https://[PROJECT_ID].supabase.co/auth/v1",
    "Audience": "authenticated",
    "ClientId": "[CLIENT_ID]",
    "ClientSecret": "[CLIENT_SECRET]"
  },

  "Cors": {
    "AllowedOrigins": "https://yourdomain.com,https://app.yourdomain.com,http://localhost:3000"
  },

  "Caching": {
    "HeatMapTtlMinutes": 240,
    "TestSelectionTtlMinutes": 30,
    "DashboardMetricsTtlMinutes": 5,
    "CacheKeyPrefix": "INTEGRITY:PROD:"
  },

  "Features": {
    "EnableHeatMapGeneration": true,
    "EnableTestSelection": true,
    "EnableRiskAssessment": true,
    "EnableRealTimeDashboards": true,
    "EnableMachineLearning": true,
    "EnableWebhooks": true
  },

  "Integrations": {
    "AzureDevOps": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 100
    },
    "SonarQube": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 50
    },
    "GitHub": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerHour": 5000
    },
    "GitLab": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 100
    },
    "Datadog": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 60
    },
    "Slack": {
      "Enabled": true,
      "DefaultTimeout": 10,
      "RateLimitPerMinute": 300
    }
  },

  "DatabaseOptions": {
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 10,
    "CommandTimeout": 300
  },

  "Security": {
    "RequireHttps": true,
    "AllowInvalidCerts": false,
    "EncryptionKeyVaultUri": "https://[VAULT_NAME].vault.azure.net/",
    "EncryptionKeyName": "integrity-credentials-encryption-key"
  },

  "ApplicationInsights": {
    "InstrumentationKey": "[INSTRUMENTATION_KEY]",
    "SamplingPercentage": 100,
    "EnableAdaptiveSampling": true
  },

  "AzureServiceBus": {
    "ConnectionString": "Endpoint=sb://[NAMESPACE].servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=[KEY]",
    "QueueName": "integrity-async-jobs"
  }
}
