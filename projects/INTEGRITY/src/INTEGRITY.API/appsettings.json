{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:[server].database.windows.net,1433;Initial Catalog=[database];Persist Security Info=False;User ID=[username];Password=[password];MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "Redis": "localhost:6379"
  },

  "Auth": {
    "Authority": "https://login.microsoftonline.com/[tenant-id]/v2.0",
    "Audience": "https://[app-id-uri]",
    "ClientId": "[client-id]",
    "ClientSecret": "[client-secret]"
  },

  "Cors": {
    "AllowedOrigins": "http://localhost:3000,http://localhost:3001"
  },

  "Caching": {
    "HeatMapTtlMinutes": 240,
    "TestSelectionTtlMinutes": 30,
    "DashboardMetricsTtlMinutes": 5,
    "CacheKeyPrefix": "INTEGRITY:"
  },

  "Features": {
    "EnableHeatMapGeneration": true,
    "EnableTestSelection": true,
    "EnableRiskAssessment": true,
    "EnableRealTimeDashboards": false,
    "EnableMachineLearning": false,
    "EnableWebhooks": true
  },

  "Integrations": {
    "AzureDevOps": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 100
    },
    "SonarQube": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 50
    },
    "GitHub": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerHour": 5000
    },
    "GitLab": {
      "Enabled": true,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 100
    },
    "Datadog": {
      "Enabled": false,
      "DefaultTimeout": 30,
      "RateLimitPerMinute": 60
    },
    "Slack": {
      "Enabled": true,
      "DefaultTimeout": 10,
      "RateLimitPerMinute": 300
    }
  },

  "DatabaseOptions": {
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 10,
    "CommandTimeout": 300
  },

  "Security": {
    "EncryptionKeyVaultUri": "https://[vault-name].vault.azure.net/",
    "EncryptionKeyName": "integrity-credentials-encryption-key",
    "RequireHttps": true,
    "AllowInvalidCerts": false
  },

  "ApplicationInsights": {
    "InstrumentationKey": "[instrumentation-key]",
    "SamplingPercentage": 100,
    "EnableAdaptiveSampling": true
  },

  "AzureServiceBus": {
    "ConnectionString": "Endpoint=sb://[namespace].servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=[key]",
    "QueueName": "integrity-async-jobs"
  }
}
