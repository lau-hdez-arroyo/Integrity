# Supabase Cloud Configuration
# Copy this file to .env and fill in your Supabase credentials

# ===== SUPABASE CLOUD CREDENTIALS =====
ASPNETCORE_ENVIRONMENT=Supabase.Production
SUPABASE_URL=https://omxyeagavmybmyqppudf.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_UEbY4BlonnynGiN7j4c_rg_S3C1nv7c
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== DATABASE CONNECTION =====
# Option 1: REST API (recommended)
DefaultConnection=https://omxyeagavmybmyqppudf.supabase.co

# Option 2: Direct PostgreSQL (if using EF Core with Npgsql)
# DefaultConnection=Host=omxyeagavmybmyqppudf.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require

# ===== REDIS CACHE =====
REDIS_CONNECTION_STRING=localhost:6379

# ===== APPLICATION SETTINGS =====
ASPNETCORE_URLS=http://localhost:5000
ASPNETCORE_HTTPS_URLS=https://localhost:5001

# ===== AZURE KEY VAULT (Production Only) =====
# AZURE_KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ===== LOGGING =====
LOGGING_LEVEL=Information
